# Environment Variables for James Banana Staking
# Copy this file to .env and fill in your values

# Reown (WalletConnect) Project ID
# Get yours at https://cloud.reown.com/
# IMPORTANT: Add your domain to Allowed Origins in the Reown dashboard:
#   https://jamesbanana.xyz
#   https://www.jamesbanana.xyz
#   http://localhost:3000
#   http://localhost:5173
VITE_REOWN_PROJECT_ID=your_project_id_here

# Optional: Custom Monad RPC URL (defaults to https://rpc.monad.xyz)
# VITE_MONAD_RPC_URL=https://rpc.monad.xyz

# Optional: Supabase (for indexer/public activity features)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key_here
